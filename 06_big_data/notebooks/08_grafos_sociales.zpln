    {
      "text": "%pyspark\n\n# Seleccionar todas las columnas de las aristas\neTops = veTops.select(\"e.*\")\n\n# Imprimir el esquema de las aristas\neTops.printSchema()\n\n# Crear un nuevo grafo con los usuarios influyentes y las aristas seleccionadas\ngTops = GraphFrame(ciTops, eTops)\n\n\n# guardo un csv con los vertices para Gephi\n# Label es igual a la id\ngTops.vertices \\\n        .select(\"*\", col(\"id\").alias(\"Label\")) \\\n        .coalesce(1) \\\n        .write \\\n        .csv(\"logs/top_influencers.csv\", mode=\"overwrite\", header=True)\n\n# guardo un csv con las aristas para Gephi\ngTops.edges \\\n        .select(col(\"src\").alias(\"Source\"), \n                col(\"dst\").alias(\"Target\"), \n                \"count_RT\",\"count_distinct_RT\") \\\n        .coalesce(1) \\\n        .write \\\n        .csv(\"logs/top_edges.csv\", mode=\"overwrite\", header=True)\n",
      "user": "anonymous",
      "dateUpdated": "2023-10-25T18:11:40-0300",
      "progress": 0,
