      "results": {
        "code": "SUCCESS",
        "msg": [
          {
            "type": "HTML",
            "data": "<div class=\"markdown-body\">\n<h2>Visualización</h2>\n<p>A continuación visualizaremos con <a href=\"https://gephi.org/\">Gephi</a> la parte del grafo (subgrafo) que contiene los mayores influencers.</p>\n<p>Para ello generaremos archivos <em>csv</em> como entrada de esta herramienta</p>\n</div>"
          }
        ]
      },
      "apps": [],
      "runtimeInfos": {},
      "progressUpdateIntervalMs": 500,
      "jobName": "paragraph_1698263489913_2053203787",
      "id": "20171102-160936_360694508",
      "dateCreated": "2023-10-25T16:51:29-0300",
      "status": "READY",
      "$$hashKey": "object:487"
    },
    {
      "text": "%pyspark\n\n# Definir umbrales para influencia colectiva y grado mínimo\nminCI = 29000000\nminDegree = 600\n\n# tomo los usarios con mayor influencia o con más conecciones\nciTops = collectiveInfluence \\\n    .filter((col(\"ci\") >= minCI) | (col(\"degree\") >= minDegree))\n\n# Crear un nuevo grafo con los usuarios influentes\ngInfluencers = GraphFrame(ciTops, graph.edges)\n\n# Encontrar las aristas entre los usuarios influentes\nveTops = gInfluencers.find(\"(a)-[e]->(b)\") \\\n                .cache()\n      \n# Imprimir la cantidad de top influencers y el esquema de las aristas\nprint(\"Cantidad de top influencers:\", veTops.count())\nveTops.printSchema()\n",
      "user": "anonymous",
      "dateUpdated": "2023-10-25T18:09:52-0300",
      "progress": 0,
      "config": {
