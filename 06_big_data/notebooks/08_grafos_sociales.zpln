    {
      "title": "Guardemos el grafo",
      "text": "%pyspark\n\nfrom pyspark.sql.functions import col\n\n# Imprime el esquema del DataFrame de aristas \"g.edges\".\ng.edges.printSchema()\n\n# Realiza una selección de columnas y cambia los nombres de las columnas \"src\" y \"dst\" a \"Source\" y \"Target\" respectivamente.\n# También selecciona la columna \"relationship\".\ng.edges \\\n        .select(col(\"src\").alias(\"Source\"), \n                col(\"dst\").alias(\"Target\"), \n                \"relationship\") \\\n        .coalesce(1) \\\n        .write \\\n        .csv(\"g_edges.csv\", mode=\"overwrite\", header=True)\n# Utiliza coalesce(1) para reducir el número de particiones del DataFrame a 1, lo que genera un solo archivo de salida en lugar de múltiples.\n\n# Ver que pasa sin coalesce",
      "user": "anonymous",
