    {
      "title": "Estimador (Decision Tree Classifier)",
      "text": "%pyspark\n\nfrom pyspark.ml import Pipeline\n\n# Creo el pipeline con los Transformers y el Estimator\npipeline = Pipeline(stages=[vAssembler, sexIndexer, dtEstimator])\n\n# Con fit el pipeline genera los fetures y entrena.\npipModel = pipeline.fit(trainDF)\n\nprint(\"%table\\nStage\")\nfor stage in pipModel.stages:\n    print(stage)\n",
