      "text": "%pyspark\n\nfrom pyspark.ml.feature import VectorAssembler\n\nvAssembler = VectorAssembler(\n    inputCols=[\"kgs\", \"mts\"],\n    outputCol=\"features\")\ntrainAssembled = vAssembler.transform(trainDF)\n\nz.show(trainAssembled.sample(False, 0.001))",
