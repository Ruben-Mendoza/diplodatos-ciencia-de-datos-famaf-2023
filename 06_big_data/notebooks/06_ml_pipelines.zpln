    {
      "title": "Dividimos los datos en train & test",
      "text": "%pyspark\n\ntrainDF, testDF = people.randomSplit([0.90, 0.10]) \n\nprint(f\"\"\"%table\nCantidad Train \\t Cantidad Test\n{trainDF.count()} \\t {testDF.count()}\n\"\"\")\n",
