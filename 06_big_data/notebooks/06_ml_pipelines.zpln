    {
      "title": "Leemos los datos de entrada",
      "text": "%pyspark\n# Especifica la ubicación del archivo JSON que se leerá.\ninputFile = \"../../diplodatos_bigdata/ds/people_sex_height_age_weight.json\"\n\n# Lee el archivo JSON y crea un DataFrame llamado 'people'.\npeople = spark.read.json(inputFile) \\\n    .select(\"kgs\", \"mts\", \"sex\") \\\n    .repartition(sc.defaultParallelism) \\\n    .cache()\n    \nprint(\"Cantidad de filas: {}. Cantidad de particiones: {}.\".format(people.count(), people.rdd.getNumPartitions()))\n\nz.show(people.sample(False,0.001))",
      "user": "anonymous",
      "dateUpdated": "2023-11-03T13:23:16-0300",
      "progress": 0,
      "config": {
        "editorSetting": {
