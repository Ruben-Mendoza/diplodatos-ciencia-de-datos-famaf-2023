      },
      "apps": [],
      "runtimeInfos": {},
      "progressUpdateIntervalMs": 500,
      "jobName": "paragraph_1697236200395_593058640",
      "id": "20171016-232257_285172371",
      "dateCreated": "2023-10-13T22:30:00+0000",
      "status": "READY",
      "$$hashKey": "object:97"
    },
    {
      "text": "%pyspark\n\n# Lo que hace la funcion es leer el archivo CSV y omitir la primera fila que tiene los titulos \ninput = sc.textFile(\"/diplodatos_bigdata/ds/flights.csv\").filter(lambda line: \"AirTime\" not in line)\n\n\n# Función lambda dado que tenemos valores no definidos\n\nconvertir_a_int = lambda x: int(x) if x.strip() and x != 'NA' else 0\n\n# Convertir los valores a enteros\ncolum_tiempo_vuelo = input.map(lambda l: l.split(\",\")[13]).map(convertir_a_int)\n\n# Calcular el máximo valor en la columna de tiempo de vuelo\nmax_tiempo_vuelo = colum_tiempo_vuelo.max()\n\nprint(\"Tiempo de vuelo máximo: {} minutos\".format(max_tiempo_vuelo))\n",
      "user": "anonymous",
      "dateUpdated": "2023-10-14T15:12:14+0000",
      "progress": 0,
