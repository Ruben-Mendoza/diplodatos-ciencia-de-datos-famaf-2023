    {
      "title": "",
      "text": "%pyspark\n\ninput = sc.textFile(\"/diplodatos_bigdata/ds/flights.csv\") \n\nnTotal = input.count() - 1 # la primer fila tiene el nombre de las columnas\n\nparsed = input.map(lambda l: l.split(\",\"))\n\ncancel = parsed.filter(lambda l: l[22] == '1') # Completar\n\nredir = parsed.filter(lambda l: l[24] == '1')\n\nnCancel = cancel.count()\nnRedir = redir.count()\n\nprint(\"Porcentaje de vuelos cancelados = {}%\".format(float(nCancel) * 100 / nTotal))\nprint(\"Porcentaje de vuelos redirigidos = {}%\".format(float(nRedir) * 100 / nTotal))\n",
      "user": "anonymous",
