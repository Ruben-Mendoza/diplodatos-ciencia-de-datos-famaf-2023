    {
      "text": "%md\n\n## ~.- Resilient Distributed Dataset (RDD)\n",
      "user": "anonymous",
      "dateUpdated": "2023-10-13T22:30:00+0000",
      "progress": 0,
      "config": {
        "tableHide": false,
        "editorSetting": {
